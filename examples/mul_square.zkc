// c = (a * b)^2, with a and b secret.
//
// No advice anywhere: every wire is computed *and* constrained by `let`,
// so this circuit is sound by construction. Note also that the compiler
// shares the repeated `a * b` (CSE) — check the optimizer line.
circuit MulSquare {
    private a: field;
    private b: field;
    public c: field;

    let ab = a * b;
    assert c == ab * ab;
}
